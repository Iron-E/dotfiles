{
	"editorconfig": {
		"body": [
			"root = true",
			"",
			"[*]",
			"charset = utf-8",
			"end_of_line = lf",
			"indent_size = ${1|tab,2,4|} ",
			"indent_style = ${2|space,tab|}",
			"insert_final_newline = true",
			"trim_trailing_whitespace = true",
			"#tab_width = 3"
		],
		"prefix": "editorconfig"
	}
}
